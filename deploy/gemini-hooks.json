{
  "safety-gate": {
    "enabled": true,
    "PreToolUse": [
      {
        "matcher": "run_command|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node.exe __USER_HOME__/.gemini/hooks/check-shell-policy-gemini.js",
            "statusMessage": "Checking shell policy (Gemini)..."
          }
        ]
      }
    ]
  }
}
