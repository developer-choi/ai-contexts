{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('path').join(require('os').homedir(),'.codex','hooks','auto-stage-new-file.js'))\"",
            "statusMessage": "Auto-staging new file..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('path').join(require('os').homedir(),'.codex','hooks','check-shell-policy.js'))\"",
            "statusMessage": "Checking shell policy..."
          },
          {
            "type": "command",
            "command": "node -e \"require(require('path').join(require('os').homedir(),'.codex','hooks','check-git-staging-policy.js'))\"",
            "statusMessage": "Checking git staging policy..."
          },
          {
            "type": "command",
            "command": "node -e \"require(require('path').join(require('os').homedir(),'.codex','hooks','check-git-commit-policy.js'))\"",
            "statusMessage": "Checking git commit policy..."
          },
          {
            "type": "command",
            "command": "node -e \"require(require('path').join(require('os').homedir(),'.codex','hooks','check-git-push-policy.js'))\"",
            "statusMessage": "Checking git push policy..."
          },
          {
            "type": "command",
            "command": "node -e \"require(require('path').join(require('os').homedir(),'.codex','hooks','check-team-message-policy.js'))\"",
            "statusMessage": "Checking team message policy..."
          }
        ]
      }
    ]
  }
}
